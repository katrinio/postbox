################################################################################
# Postbox Configuration
#
# REQUIRED in production (do not leave at defaults):
#   - POSTBOX_JWT_SECRET_KEY: generate with: openssl rand -hex 32
#   - POSTBOX_PUBLIC_URL: set to your public domain (https://postbox.finpipe.net)
#
# Development defaults are safe; production defaults are intentionally unsafe.
################################################################################

# ----------
# Local SQLite for small deployments (recommended for first deployment)
POSTBOX_DATABASE_URL=sqlite:////data/postbox.db

# For development on macOS: PostgreSQL via brew
# POSTBOX_DATABASE_URL=postgresql+psycopg://postbox:postbox@127.0.0.1:5432/postbox


# SECURITY (REQUIRED in production)
# ----------
# JWT secret for session tokens. Generate a strong random value:
#   openssl rand -hex 32
# NEVER use the same secret across multiple environments.
POSTBOX_JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters

# Public HTTPS URL where Postbox is accessible.
# Required for Telegram Web App authentication.
# Example: https://postbox.finpipe.net
POSTBOX_PUBLIC_URL=replace-with-your-public-domain

# Telegram Bot token (if bot features are added later).
# Obtain from BotFather: @BotFather /newbot
# POSTBOX_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11


# APPLICATION SETTINGS
# ----------
# Maximum number of auto-approved users (new users after this limit require approval)
POSTBOX_REGISTRATION_LIMIT=5

# Log level: DEBUG, INFO (default), WARNING, ERROR
POSTBOX_LOG_LEVEL=INFO

# Frontend API URL. Leave empty to use relative /api paths (recommended for production).
# Set to http://localhost:8000 for local development without a reverse proxy.
NEXT_PUBLIC_POSTBOX_API_URL=

# API server binding (Docker: use 127.0.0.1; exposed to reverse proxy only)
POSTBOX_API_HOST=127.0.0.1
POSTBOX_API_PORT=8000

# API hot-reload (development only; set to false for production)
POSTBOX_API_RELOAD=false
