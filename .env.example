# Database URL (PostgreSQL on macOS via brew: 127.0.0.1:55432)
POSTBOX_DATABASE_URL=postgresql+psycopg://postbox:postbox@127.0.0.1:55432/postbox

# JWT secret key for session tokens (change in production!)
POSTBOX_JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Maximum number of registered users (auto-approve first N, then reject new)
POSTBOX_REGISTRATION_LIMIT=5

# Optional: Telegram bot token (for future bot features)
# POSTBOX_BOT_TOKEN=your-bot-token-from-botfather

# Optional: Log level
# POSTBOX_LOG_LEVEL=INFO
