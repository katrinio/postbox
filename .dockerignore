# ============================================================================
# Docker build exclusions - be conservative with source files
# ============================================================================

# Version control
.git
.gitignore
.github

# Environment and secrets
.env
.env.local
.env.*.local
.env.example

# Virtual environments
.venv
venv/
env/

# Python build artifacts and caches (NOT web/build/)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/  # Python package build artifacts (not web/)
dist/   # Python distribution artifacts (not web/)

# Node runtime artifacts (NOT source)
node_modules/
web/node_modules/
web/.next/
web/dist/
.wrangler/
.vinext/

# Application runtime data (never copy into image)
data/
backups/
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Logs and temporary
*.log
*.tmp
.DS_Store
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Testing and coverage
.coverage
htmlcov/
coverage/

# Other unneeded
.cache/
.dyno.log
